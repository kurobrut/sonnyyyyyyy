--// TWEEN TELEPORT (SMOOTH)
local function tp(block)
	local char = player.Character
	if char and char:FindFirstChild("HumanoidRootPart") then
		
		local root = char.HumanoidRootPart
		local targetCFrame = block.HumanoidRootPart.CFrame * CFrame.new(0,0,3)

		local tween = TweenService:Create(
			root,
			TweenInfo.new(0.25, Enum.EasingStyle.Linear),
			{CFrame = targetCFrame}
		)

		tween:Play()
	end
end

--// LOOP
local function farmLoop()
	while autoFarm do
		
		-- Equip using remote + force visual
		if not equipped then
			pcall(function()
				equipRemote:FireServer()
			end)

			task.wait(0.2)

			local tool = getTool()
			if not tool then
				tool = equipTool()
			end

			if tool then
				equipped = true
			end
		end

		local tool = getTool()
		if not tool then
			equipped = false
		end

		local block = getNearestBlock()
		if block then
			tp(block)
		end

		if tool then
			tool:Activate()
		end

		task.wait(0.4)
	end
end

--// TOGGLE FUNCTION
local function toggleFarm()
	autoFarm = not autoFarm
	
	if autoFarm then
		equipped = false
		
		button.BackgroundColor3 = Color3.fromRGB(200,255,200)
		button.BackgroundTransparency = 0.3
		stroke.Color = Color3.fromRGB(0,180,0)
		label.TextColor3 = Color3.fromRGB(0,180,0)
		
		task.spawn(farmLoop)
	else
		equipped = false
		
		button.BackgroundColor3 = Color3.fromRGB(255,255,255)
		button.BackgroundTransparency = 0.5
		stroke.Color = Color3.fromRGB(0,0,0)
		label.TextColor3 = Color3.fromRGB(0,200,0)
	end
end

--// BUTTON CLICK
button.Activated:Connect(toggleFarm)

--// KEYBIND (PRESS F)
UIS.InputBegan:Connect(function(input, gp)
	if gp then return end
	
	if input.KeyCode == Enum.KeyCode.F then
		toggleFarm()
	end
end)
